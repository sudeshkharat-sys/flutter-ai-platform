name: {{ app_name_slug }}
description: AI Vision App — {{ app_name }} — generated by Flutter AI Studio
version: 1.0.0+1
publish_to: 'none'

environment:
  sdk: '>=3.0.0 <4.0.0'

dependencies:
  flutter:
    sdk: flutter
  camera: ^0.11.0+2
  tflite_flutter: ^0.12.0
  image: ^4.2.0
  permission_handler: ^11.3.1
  mobile_scanner: ^3.5.2
  path_provider: ^2.1.2
  shared_preferences: ^2.2.2
  drift: ^2.16.0
  sqlite3_flutter_libs: ^0.5.20
  path: ^1.9.0
  zsdk: 5.0.0

dependency_overrides:
  # path_provider_android 2.3.x requires AGP 8.5+; our build uses AGP 8.1.1.
  # Force the last compatible version here and in settings.gradle.
  path_provider_android: 2.2.22
  # sqlite3 3.x introduced a build hook that downloads libsqlite3.x64.android.so
  # from a CDN at Flutter build time.  The hash of the file currently served by
  # the CDN does not match the expected hash embedded in sqlite3 3.3.1, causing
  # the Flutter build to abort with "Bad state: Hash of downloaded file …".
  # sqlite3 2.x has no download hook — it uses sqlite3_flutter_libs (already
  # listed in dependencies) to supply the pre-built native binary, which is the
  # correct approach for a packaged Flutter app.  drift 2.x accepts both lines.
  sqlite3: '>=2.4.0 <3.0.0'

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^3.0.0
  drift_dev: ^2.16.0
  build_runner: ^2.4.8

flutter:
  uses-material-design: true
  assets:
    - assets/models/
    - assets/models_manifest.json
    - assets/master_data.json
    - assets/reference_images/
