plugins {
    id "com.android.application"
    id "dev.flutter.flutter-gradle-plugin"
    id "org.jetbrains.kotlin.android"
}

def localProperties = new Properties()
def localPropertiesFile = rootProject.file('local.properties')
if (localPropertiesFile.exists()) {
    localPropertiesFile.withReader('UTF-8') { reader ->
        localProperties.load(reader)
    }
}

android {
    namespace "{{ package_name }}"
    compileSdk rootProject.ext.flutterCompileSdkVersion
    ndkVersion "27.0.12077973"

    defaultConfig {
        applicationId "{{ package_name }}"
        minSdk rootProject.ext.flutterMinSdkVersion
        targetSdk rootProject.ext.flutterTargetSdkVersion
        versionCode 1
        versionName "1.0"
    }

    compileOptions {
        sourceCompatibility JavaVersion.VERSION_17
        targetCompatibility JavaVersion.VERSION_17
    }

    kotlinOptions {
        jvmTarget = '17'
    }

    sourceSets {
        main.java.srcDirs += 'src/main/kotlin'
    }

    buildTypes {
        release {
            signingConfig signingConfigs.debug
        }
    }
}

// CRITICAL: Disable AAR metadata checks that force AGP 8.6.0 for camera dependencies
tasks.withType(com.android.build.gradle.internal.tasks.CheckAarMetadataTask).configureEach {
    enabled = false
}

flutter {
    source '../..'
}

dependencies {
    implementation "org.jetbrains.kotlin:kotlin-stdlib:1.9.20"

    // androidx deps required by FlutterActivity's supertypes (FragmentActivity,
    // LifecycleOwner etc.).  The Flutter Gradle plugin adds these transitively at
    // runtime, but the Kotlin compiler needs them on the classpath at compile time.
    implementation "androidx.core:core:1.12.0"
    implementation "androidx.lifecycle:lifecycle-common:2.6.2"
    implementation "androidx.lifecycle:lifecycle-runtime:2.6.2"
    implementation "androidx.activity:activity:1.8.0"
    implementation "androidx.fragment:fragment:1.6.2"

    // Flutter engine jar — provides io.flutter.* classes for compilation.
    def flutterSdk = localProperties.getProperty('flutter.sdk')
                  ?: System.getenv("FLUTTER_ROOT") ?: "C:/flutter"
    compileOnly files("$flutterSdk/bin/cache/artifacts/engine/android-arm64-release/flutter.jar",
                      "$flutterSdk/bin/cache/artifacts/engine/android-arm-release/flutter.jar",
                      "$flutterSdk/bin/cache/artifacts/engine/android-x64-release/flutter.jar")
}
