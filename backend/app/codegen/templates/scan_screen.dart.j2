import 'dart:convert';
import 'package:flutter/material.dart';
import 'package:flutter/services.dart';
import 'package:mobile_scanner/mobile_scanner.dart';
import 'home_screen.dart';
import 'history_screen.dart';

class ScanScreen extends StatefulWidget {
  final String modelCode;
  const ScanScreen({super.key, required this.modelCode});

  @override
  State<ScanScreen> createState() => _ScanScreenState();
}

class _ScanScreenState extends State<ScanScreen> with WidgetsBindingObserver {
  bool _isProcessing = false;
  List<dynamic> _scanData = [];

  final MobileScannerController _scannerController = MobileScannerController(
    detectionSpeed: DetectionSpeed.noDuplicates,
    facing: CameraFacing.back,
  );

  @override
  void initState() {
    super.initState();
    WidgetsBinding.instance.addObserver(this);
    _loadScanData();
  }

  Future<void> _loadScanData() async {
    try {
{% if scan_type == 'engine' %}
      final String jsonStr = await rootBundle.loadString('assets/engine_data.json');
{% else %}
      final String jsonStr = await rootBundle.loadString('assets/master_data.json');
{% endif %}
      final List<dynamic> data = json.decode(jsonStr);
      if (mounted) {
        setState(() => _scanData = data);
      }
    } catch (e) {
      debugPrint('Could not load scan data: $e');
    }
  }

  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    _scannerController.dispose();
    super.dispose();
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState state) {
    if (state == AppLifecycleState.resumed) {
      _scannerController.start();
    } else if (state == AppLifecycleState.inactive) {
      _scannerController.stop();
    }
  }

  void _showErrorDialog(String message) {
    _scannerController.stop();
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (ctx) => AlertDialog(
        title: const Text('Invalid Barcode', style: TextStyle(color: Color(0xFFDC143C), fontWeight: FontWeight.bold)),
        content: Text(message),
        actions: [
          TextButton(
            onPressed: () {
              Navigator.of(ctx).pop();
              if (mounted) {
                setState(() => _isProcessing = false);
                _scannerController.start();
              }
            },
            child: const Text('OK', style: TextStyle(color: Color(0xFFDC143C))),
          ),
        ],
      ),
    );
  }

{% if scan_type == 'engine' %}
  // ── Engine Code Scan Logic ────────────────────────────────────────────────
  // Barcode format: "PART_NO SERIAL_NO"  (split at first space)
  // Left  → match against engine_data.json (part_no field)
  // Right → engine serial number → saved to history

  bool _isKnownEngineCode(String candidate) {
    if (candidate.isEmpty || _scanData.isEmpty) return false;
    final upper = candidate.toUpperCase();
    return _scanData.any(
      (m) => (m['part_no'] as String? ?? '').toUpperCase() == upper,
    );
  }

  Future<void> _onDetect(BarcodeCapture capture) async {
    if (_isProcessing) return;

    final List<Barcode> barcodes = capture.barcodes;
    if (barcodes.isNotEmpty) {
      final String? code = barcodes.first.rawValue;
      if (code == null) return;

      final String raw = code.trim();
      final int spaceIdx = raw.indexOf(' ');

      if (spaceIdx == -1) {
        setState(() => _isProcessing = true);
        _showErrorDialog('Invalid engine barcode. Expected format: PART_NO SERIAL_NO');
        return;
      }

      setState(() => _isProcessing = true);

      final String partNo = raw.substring(0, spaceIdx).trim();
      final String engineSerial = raw.substring(spaceIdx + 1).trim();

      if (!_isKnownEngineCode(partNo)) {
        _showErrorDialog('Engine code not found. Please add it and rebuild the app.');
        return;
      }

      if (!mounted) return;
      _scannerController.stop();
      Navigator.of(context).push(
        MaterialPageRoute(
          builder: (context) => HomeScreen(
            vin: engineSerial,
            modelCode: partNo,
            cameras: [],
          ),
        ),
      ).then((_) {
        if (mounted) {
          setState(() => _isProcessing = false);
          _scannerController.start();
        }
      });
    }
  }

{% else %}
  // ── Model Code Scan Logic ─────────────────────────────────────────────────
  // Barcode format: [17-char VIN][suffix]
  // VIN    → stored in history
  // Suffix → stripped and matched against master_data.json (model_code field)

  bool _isKnownModelCode(String candidate) {
    if (candidate.isEmpty || _scanData.isEmpty) return false;
    final upper = candidate.toUpperCase();
    return _scanData.any(
      (m) => (m['model_code'] as String? ?? '').toUpperCase() == upper,
    );
  }

  /// Strip strategy (tried in order, first match wins):
  ///   strip-2 → remove last 2 chars
  ///   strip-1 → remove last 1 char
  ///   strip-0 → use full suffix
  String _resolveModelCode(String suffix) {
    for (final strip in [2, 1, 0]) {
      if (suffix.length > strip) {
        final candidate = suffix.substring(0, suffix.length - strip);
        if (_isKnownModelCode(candidate)) {
          return candidate;
        }
      }
    }
    if (suffix.length > 2) return suffix.substring(0, suffix.length - 2);
    return suffix;
  }

  Future<void> _onDetect(BarcodeCapture capture) async {
    if (_isProcessing) return;

    final List<Barcode> barcodes = capture.barcodes;
    if (barcodes.isNotEmpty) {
      final String? code = barcodes.first.rawValue;
      if (code == null) return;

      final String raw = code.trim();

      if (raw.length < 30 || raw.length > 35) {
        setState(() => _isProcessing = true);
        _showErrorDialog('Please scan the right VIN model code.');
        return;
      }

      setState(() => _isProcessing = true);

      final String vin = raw.substring(0, 17);
      final String suffix = raw.substring(17);
      final String extractedModelCode = _resolveModelCode(suffix);

      if (!_isKnownModelCode(extractedModelCode)) {
        _showErrorDialog('Model code is not present, please add code and rebuild app.');
        return;
      }

      if (!mounted) return;
      _scannerController.stop();
      Navigator.of(context).push(
        MaterialPageRoute(
          builder: (context) => HomeScreen(
            vin: vin,
            modelCode: extractedModelCode,
            cameras: [],
          ),
        ),
      ).then((_) {
        if (mounted) {
          setState(() => _isProcessing = false);
          _scannerController.start();
        }
      });
    }
  }

{% endif %}

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Container(
        decoration: const BoxDecoration(
          gradient: LinearGradient(
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
            colors: [Colors.white, Color(0xFFFFF5F5)],
          ),
        ),
        child: Column(
          children: [
            Container(
              width: double.infinity,
              padding: const EdgeInsets.symmetric(vertical: 16, horizontal: 16),
              decoration: const BoxDecoration(color: Color(0xFFDC143C)),
              child: SafeArea(
                bottom: false,
                child: Row(
                  mainAxisAlignment: MainAxisAlignment.center,
                  children: const [
                    Text(
                      'SCAN BARCODE',
                      style: TextStyle(
                        color: Colors.white,
                        fontSize: 20,
                        fontWeight: FontWeight.bold,
                        letterSpacing: 1.5,
                      ),
                    ),
                  ],
                ),
              ),
            ),
            Expanded(
              child: Stack(
                children: [
                  MobileScanner(
                    controller: _scannerController,
                    onDetect: _onDetect,
                  ),
                  Center(
                    child: Container(
                      width: 250,
                      height: 250,
                      decoration: BoxDecoration(
                        border: Border.all(color: const Color(0xFFDC143C), width: 2),
                      ),
                      child: Stack(
                        children: [
                          _bracket(top: 0, left: 0, isTop: true, isLeft: true),
                          _bracket(top: 0, right: 0, isTop: true, isLeft: false),
                          _bracket(bottom: 0, left: 0, isTop: false, isLeft: true),
                          _bracket(bottom: 0, right: 0, isTop: false, isLeft: false),
                        ],
                      ),
                    ),
                  ),
                  if (_isProcessing)
                    Container(
                      color: Colors.black.withOpacity(0.5),
                      child: const Center(
                        child: CircularProgressIndicator(color: Color(0xFFDC143C)),
                      ),
                    ),
                ],
              ),
            ),
            Padding(
              padding: const EdgeInsets.all(24),
              child: SizedBox(
                width: double.infinity,
                child: ElevatedButton(
                  onPressed: () => Navigator.push(context, MaterialPageRoute(builder: (_) => const HistoryScreen())),
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFFDC143C),
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 16),
                    shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8)),
                  ),
                  child: const Text('VIEW HISTORY', style: TextStyle(fontWeight: FontWeight.bold)),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }

  Widget _bracket({double? top, double? bottom, double? left, double? right, required bool isTop, required bool isLeft}) {
    return Positioned(
      top: top,
      bottom: bottom,
      left: left,
      right: right,
      child: Container(
        width: 30,
        height: 30,
        decoration: BoxDecoration(
          border: Border(
            top: isTop ? const BorderSide(color: Color(0xFFDC143C), width: 3) : BorderSide.none,
            bottom: !isTop ? const BorderSide(color: Color(0xFFDC143C), width: 3) : BorderSide.none,
            left: isLeft ? const BorderSide(color: Color(0xFFDC143C), width: 3) : BorderSide.none,
            right: !isLeft ? const BorderSide(color: Color(0xFFDC143C), width: 3) : BorderSide.none,
          ),
        ),
      ),
    );
  }
}
