org.gradle.jvmargs=-Xmx4G -XX:MaxMetaspaceSize=1G -XX:+HeapDumpOnOutOfMemoryError -Dfile.encoding=UTF-8
systemProp.file.encoding=UTF-8

# FIX: Disable incremental compilation to allow cross-drive (C: to D:) bridging
kotlin.incremental=false
kotlin.incremental.java=false
kotlin.incremental.js=false

android.useAndroidX=true
android.enableJetifier=true
android.ignoreAarMetadataCheck=true

# FIX: Opt out of AGP 9+ new DSL mode — required for Flutter Gradle plugin
# compatibility. Without this, camera_android_camerax throws NullPointerException
# during project evaluation and the build fails.
android.newDsl=false
