pluginManagement {
    def flutterSdkPath = {
        def properties = new Properties()
        def localPropertiesFile = file("local.properties")
        if (localPropertiesFile.exists()) {
            localPropertiesFile.withInputStream { properties.load(it) }
        }
        def flutterSdkPath = properties.getProperty("flutter.sdk")
        if (flutterSdkPath == null) {
            flutterSdkPath = System.getenv("FLUTTER_ROOT") ?: System.getenv("FLUTTER_HOME")
        }
        return flutterSdkPath
    }()

    includeBuild("$flutterSdkPath/packages/flutter_tools/gradle")

    repositories {
        google()
        mavenCentral()
        gradlePluginPortal()
    }
}

plugins {
    id "dev.flutter.flutter-gradle-plugin" version "1.0.0" apply false
    id "com.android.application" version "8.1.1" apply false
    id "org.jetbrains.kotlin.android" version "1.9.20" apply false
}

include ":app"

// --- DYNAMIC PLUGIN BRIDGING ---
// Discover the Flutter pub cache at runtime so the build works for any user /
// machine without hardcoded paths.  Resolution order:
//   1. PUB_CACHE env var (set by the Flutter tool itself on some systems)
//   2. %LOCALAPPDATA%\Pub\Cache  (Windows default)
//   3. ~/.pub-cache              (macOS / Linux default)
def pubCacheHosted = { ->
    def envCache = System.getenv("PUB_CACHE")
    if (envCache) return envCache.replace('\\', '/') + "/hosted/pub.dev"

    def localAppData = System.getenv("LOCALAPPDATA")
    if (localAppData) {
        def p = new File(localAppData, "Pub/Cache/hosted/pub.dev")
        if (p.exists()) return p.absolutePath.replace('\\', '/')
    }

    def home = System.getProperty("user.home")
    def win = new File(home, "AppData/Local/Pub/Cache/hosted/pub.dev")
    if (win.exists()) return win.absolutePath.replace('\\', '/')

    def unix = new File(home, ".pub-cache/hosted/pub.dev")
    if (unix.exists()) return unix.absolutePath.replace('\\', '/')

    // Last-resort guess (path may not exist yet, but avoids NPE)
    return (localAppData ?: (home + "/AppData/Local")) + "/Pub/Cache/hosted/pub.dev"
}()

// Find the Android subdirectory for any installed version of a plugin.
// e.g. findPluginAndroid("camera_android_camerax") returns
//      <cache>/camera_android_camerax-0.6.30/android (if it exists).
def findPluginAndroid = { String pluginName ->
    def cacheRoot = new File(pubCacheHosted)
    if (!cacheRoot.exists()) return null
    def match = cacheRoot.listFiles()?.find { f ->
        f.isDirectory() && (f.name == pluginName || f.name.startsWith(pluginName + "-"))
    }
    return match ? new File(match, "android") : null
}

// Plugins that ship Android native code and must be compiled as subprojects.
// Only plugins resolved by 'flutter pub get' belong here.
def androidPlugins = [
    "camera_android_camerax",
    "flutter_plugin_android_lifecycle",
    "permission_handler_android",
    "path_provider_android",
    "shared_preferences_android",
    "mobile_scanner",
    "sqlite3_flutter_libs",
    "zsdk",
    "tflite_flutter",
]

androidPlugins.each { pluginName ->
    def androidDir = findPluginAndroid(pluginName)
    if (androidDir?.exists()) {
        include ":$pluginName"
        project(":$pluginName").projectDir = androidDir
    }
}
