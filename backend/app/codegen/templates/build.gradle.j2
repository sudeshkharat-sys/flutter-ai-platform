// Global properties for the app project
ext {
    flutterCompileSdkVersion = 36
    flutterMinSdkVersion = 26
    flutterTargetSdkVersion = 36
}

// FlutterLocalExtension is defined in buildSrc/src/main/groovy/ so it is
// compiled before this script runs and is on the classpath for all build
// scripts including Kotlin DSL (.kts) files in plugin subprojects.

// Robustly load local.properties to get Flutter SDK path
def getFlutterSdkPath() {
    def properties = new Properties()
    def localPropertiesFile = rootProject.file('local.properties')
    if (localPropertiesFile.exists()) {
        localPropertiesFile.withReader('UTF-8') { reader ->
            properties.load(reader)
        }
    }
    def sdkPath = properties.getProperty('flutter.sdk')
    if (sdkPath == null) {
        sdkPath = System.getenv("FLUTTER_ROOT") ?: System.getenv("FLUTTER_HOME")
    }
    return sdkPath
}

def flutterSdkPath = getFlutterSdkPath()

// Share the SDK path with all subprojects
ext.flutterSdkPath = flutterSdkPath

allprojects {
    repositories {
        google()
        mavenCentral()
        if (flutterSdkPath != null) {
            // Manual bridging: Point to local Flutter engine artifacts
            maven {
                url "$flutterSdkPath/bin/cache/artifacts/engine"
            }
        }
    }
    
    // Inject properties into every project's extension so they are available as 'flutter.XXX'
    project.ext {
        set("flutter.compileSdkVersion", rootProject.ext.flutterCompileSdkVersion)
        set("flutter.minSdkVersion", rootProject.ext.flutterMinSdkVersion)
        set("flutter.targetSdkVersion", rootProject.ext.flutterTargetSdkVersion)
    }

    // Force AGP 8.7.0 across all subproject dependency resolution
    if (project != rootProject) {
        project.configurations.all {
            resolutionStrategy.eachDependency { details ->
                if (details.requested.group == 'com.android.tools.build' && details.requested.name == 'gradle') {
                    details.useVersion '8.7.0'
                }
            }
        }
    }
}

// Manual bridging for plugins that expect 'android.flutter' property or missing symbols
subprojects {
    // Inject properties as soon as the Android plugins are applied
    project.plugins.withId('com.android.library') {
        injectFlutterExtension(project)
    }
    project.plugins.withId('com.android.application') {
        injectFlutterExtension(project)
    }
}

def injectFlutterExtension(p) {
    // Register 'flutter' as a typed FlutterLocalExtension on the project so
    // that both Groovy and Kotlin DSL (.kts) plugin build files can access
    // flutter.compileSdkVersion / flutter.minSdkVersion / flutter.targetSdkVersion.
    // Skip the :app project — it gets the real FlutterExtension from the plugin.
    if (p.name != "app" && p.extensions.findByName("flutter") == null) {
        def ext = new FlutterLocalExtension()
        ext.compileSdkVersion = rootProject.ext.flutterCompileSdkVersion
        ext.minSdkVersion     = rootProject.ext.flutterMinSdkVersion
        ext.targetSdkVersion  = rootProject.ext.flutterTargetSdkVersion
        p.extensions.add("flutter", ext)
    }

    try {
        if (p.hasProperty('android')) {
            p.android {
                compileSdk rootProject.ext.flutterCompileSdkVersion
            }
        }
    } catch (Exception ignored) {}
    
    // Inject essential dependencies for non-app projects
    if (p.name != 'app') {
        try {
            p.dependencies {
                if (rootProject.ext.flutterSdkPath) {
                    def flutterJarPath = "${rootProject.ext.flutterSdkPath}/bin/cache/artifacts/engine/android-arm-release/flutter.jar"
                    compileOnly p.files(flutterJarPath)
                }
                implementation "androidx.annotation:annotation:1.7.0"
                implementation "androidx.core:core:1.12.0"
                implementation "androidx.lifecycle:lifecycle-common:2.6.2"
                implementation "androidx.lifecycle:lifecycle-runtime:2.6.2"
            }
        } catch (Exception ignored) {}
    }
}

// Fix AGP 8.x: inject namespace for any library that omits it in build.gradle
// (e.g. bluetooth_print). Namespace is derived from the package attribute in
// the module's AndroidManifest.xml, which is the correct migration path.
subprojects {
    afterEvaluate { proj ->
        if (proj.plugins.hasPlugin('com.android.library')) {
            try {
                def ns = proj.android.namespace
                if (!ns) {
                    def manifestFile = proj.file('src/main/AndroidManifest.xml')
                    if (manifestFile.exists()) {
                        def matcher = (manifestFile.text =~ /package="([^"]+)"/)
                        if (matcher.find()) {
                            proj.android.namespace = matcher.group(1)
                        }
                    }
                }
            } catch (Exception ignored) {}
        }
    }
}

rootProject.buildDir = '../build'
subprojects {
    project.buildDir = "${rootProject.buildDir}/${project.name}"
}

subprojects {
    project.evaluationDependsOn(':app')
}

tasks.register("clean", Delete) {
    delete rootProject.buildDir
}
