import 'package:flutter/material.dart';
import '../ml/detection_result.dart';

class StatsView extends StatelessWidget {
  final List<DetectionResult> results;
  final bool showTopClass;
  final bool showFrameCount;

  const StatsView({
    super.key,
    required this.results,
    this.showTopClass = true,
    this.showFrameCount = true,
  });

  @override
  Widget build(BuildContext context) {
    String topClass = 'None';
    if (results.isNotEmpty) {
      topClass = results.first.className;
    }

    return Container(
      margin: const EdgeInsets.symmetric(horizontal: 16, vertical: 8),
      padding: const EdgeInsets.all(16),
      decoration: BoxDecoration(
        color: const Color(0xFF0F0F13),
        borderRadius: BorderRadius.circular(16),
        border: Border.all(color: const Color(0xFF2E2E40)),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceAround,
        children: [
          if (showTopClass)
            _buildStat('Top Match', topClass, const Color(0xFF7C5CFC)),
          if (showFrameCount)
            _buildStat('Total', results.length.toString(), const Color(0xFF4CAF82)),
        ],
      ),
    );
  }

  Widget _buildStat(String label, String value, Color color) {
    return Column(
      mainAxisSize: MainAxisSize.min,
      children: [
        Text(
          label,
          style: const TextStyle(color: Colors.grey, fontSize: 11),
        ),
        const SizedBox(height: 4),
        Text(
          value,
          style: TextStyle(
            color: color,
            fontSize: 18,
            fontWeight: FontWeight.bold,
          ),
        ),
      ],
    );
  }
}
