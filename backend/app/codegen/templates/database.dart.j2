import 'package:drift/drift.dart';
import 'package:drift_flutter/drift_flutter.dart';
import 'package:path_provider/path_provider.dart';

part 'database.g.dart';

class Inspections extends Table {
  IntColumn get id => integer().autoIncrement()();
  TextColumn get vin => text()();
  TextColumn get modelCode => text()();
  DateTimeColumn get createdAt => dateTime().withDefault(currentDateAndTime)();
  BoolColumn get isSynced => boolean().withDefault(const Constant(false))();
}

class TaskResults extends Table {
  IntColumn get id => integer().autoIncrement()();
  IntColumn get inspectionId => integer().references(Inspections, #id, onDelete: KeyAction.cascade)();
  TextColumn get taskName => text()();
  TextColumn get className => text()();
  RealColumn get confidence => real()();
  BoolColumn get success => boolean()();
  TextColumn get imagePath => text().nullable()();
  TextColumn get detectionsJson => text().nullable()();
  DateTimeColumn get timestamp => dateTime().withDefault(currentDateAndTime)();
}

@DriftDatabase(tables: [Inspections, TaskResults])
class AppDatabase extends _$AppDatabase {
  AppDatabase() : super(_openConnection());

  @override
  int get schemaVersion => 2;

  @override
  MigrationStrategy get migration {
    return MigrationStrategy(
      onCreate: (m) async {
        await m.createAll();
      },
      onUpgrade: (m, from, to) async {
        if (from < 2) {
          await m.addColumn(taskResults, taskResults.imagePath);
          await m.addColumn(taskResults, taskResults.detectionsJson);
        }
      },
      beforeOpen: (details) async {
        await customStatement('PRAGMA foreign_keys = ON');
      },
    );
  }

  static QueryExecutor _openConnection() {
    return driftDatabase(
      name: 'inspection_database',
      native: const DriftNativeOptions(
        databaseDirectory: getApplicationSupportDirectory,
      ),
    );
  }

  // DAO methods
  Future<int> saveInspection(InspectionsCompanion entry) => into(inspections).insert(entry);
  Future saveTaskResult(TaskResultsCompanion entry) => into(taskResults).insert(entry);
  
  Future<List<Inspection>> getAllInspections() => (select(inspections)..orderBy([(t) => OrderingTerm.desc(t.createdAt)])).get();
  
  Future<List<TaskResult>> getResultsForInspection(int inspectionId) => 
    (select(taskResults)..where((t) => t.inspectionId.equals(inspectionId))).get();

  // For checking task progress in current session
  Future<List<TaskResult>> getLatestResultsForVin(String vin) async {
    final latest = await (select(inspections)
      ..where((t) => t.vin.equals(vin))
      ..orderBy([(t) => OrderingTerm.desc(t.createdAt)])
      ..limit(1)).getSingleOrNull();
    
    if (latest == null) return [];
    return getResultsForInspection(latest.id);
  }
}

// Global instance
final db = AppDatabase();
