import 'dart:io';
import 'package:camera/camera.dart';
import 'package:flutter/material.dart';
import 'dart:convert';
import 'dart:typed_data';
import 'package:image/image.dart' as img;
import 'package:path_provider/path_provider.dart';
import 'package:shared_preferences/shared_preferences.dart';
import '../ml/detector.dart';
import '../ml/detection_result.dart';
import '../database/database.dart';
import '../widgets/detection_overlay.dart';

class InspectionCameraScreen extends StatefulWidget {
  final String vin;
  final String modelCode;
  final List<dynamic> tasks;
  final int initialIndex;

  const InspectionCameraScreen({
    super.key,
    required this.vin,
    required this.modelCode,
    required this.tasks,
    required this.initialIndex,
  });

  @override
  State<InspectionCameraScreen> createState() => _InspectionCameraScreenState();
}

class _InspectionCameraScreenState extends State<InspectionCameraScreen>
    with WidgetsBindingObserver {
  CameraController? _cameraController;
  bool _isCameraInitialized = false;
  Uint8List? _capturedImageBytes;
  Size? _capturedImageSize;
  DetectionResult? _bestResult;
  bool _isAnalyzing = false;
  bool _isModelLoaded = false;
  bool _isLoadingModel = true;
  String? _error;

  List<String> _debugLogs = [];
  bool _showDebugConsole = false;
  bool _isFlashOn = false;

  List<DetectionResult> _allDetections = [];
  // Only the single best non-target detection is kept to avoid showing
  // multiple rows of the same class at different confidences.
  List<DetectionResult> _detectedNonTargetClasses = [];
  int _currentIndex = 0;
  final Map<int, dynamic> _results = {};

  @override
  void initState() {
    super.initState();
    _currentIndex = widget.initialIndex;
    WidgetsBinding.instance.addObserver(this);
    _initializeCamera();
    _loadCurrentModel();
    _addLog("Screen initialized for VIN: ${widget.vin}");
  }

  void _addLog(String msg) {
    if (!mounted) return;
    setState(() {
      _debugLogs.insert(
          0,
          "${DateTime.now().toString().split('.').first.split(' ').last} | $msg");
      if (_debugLogs.length > 50) _debugLogs.removeLast();
    });
    debugPrint(msg);
  }

  bool _isNotOkClass(String? className) {
    if (className == null) return false;
    final cn =
        className.toLowerCase().replaceAll('_', ' ').replaceAll('-', ' ');
    return cn.contains('not') && cn.contains('ok');
  }

  bool _isPass(String? className, List<String> targetClasses) {
    if (className == null) return false;
    if (_isNotOkClass(className)) return false;
    final cn = className.toLowerCase().trim();
    return targetClasses.any((tc) => tc.toLowerCase().trim() == cn);
  }

  Future<void> _loadCurrentModel() async {
    setState(() {
      _isLoadingModel = true;
      _isModelLoaded = false;
    });
    try {
      final task = widget.tasks[_currentIndex];
      _addLog("Loading Task: ${task['name']}");
      _addLog("TFLite: ${task['tflite_path']}");
      await ModelManager().loadModel(task['tflite_path'], task['labels_path']);
      if (mounted) {
        setState(() {
          _isLoadingModel = false;
          _isModelLoaded = true;
        });
        _addLog("Model loaded. Target: ${task['classes']}");
      }
    } catch (e) {
      _addLog("AI Init error: $e");
      if (mounted) setState(() => _error = "AI Init error: $e");
    }
  }

  @override
  void dispose() {
    WidgetsBinding.instance.removeObserver(this);
    if (_isFlashOn) {
      _cameraController?.setFlashMode(FlashMode.off).catchError((_) {});
    }
    _cameraController?.dispose();
    super.dispose();
  }

  @override
  void didChangeAppLifecycleState(AppLifecycleState state) {
    final ctrl = _cameraController;
    if (ctrl == null || !ctrl.value.isInitialized) return;
    if (state == AppLifecycleState.inactive) {
      if (_isFlashOn) {
        ctrl.setFlashMode(FlashMode.off).catchError((_) {});
        setState(() => _isFlashOn = false);
      }
      ctrl.dispose();
    } else if (state == AppLifecycleState.resumed) {
      _initializeCamera();
    }
  }

  Future<void> _initializeCamera() async {
    try {
      final cameras = await availableCameras();
      if (cameras.isEmpty) {
        _addLog('No cameras found');
        if (mounted) setState(() => _error = 'No cameras found');
        return;
      }
      final back = cameras.firstWhere(
          (c) => c.lensDirection == CameraLensDirection.back,
          orElse: () => cameras.first);
      final controller =
          CameraController(back, ResolutionPreset.medium, enableAudio: false);
      _cameraController = controller;
      await controller.initialize();
      if (mounted) setState(() => _isCameraInitialized = true);
      _addLog('Camera initialized');
    } catch (e) {
      _addLog("Camera error: $e");
      if (mounted) setState(() => _error = "Camera error: $e");
    }
  }

  Future<void> _handleCapture() async {
    if (_isAnalyzing || !_isModelLoaded || _cameraController == null) {
      _addLog(
          "Capture blocked: analyzing=$_isAnalyzing modelReady=$_isModelLoaded");
      return;
    }
    try {
      _addLog('--- Start Inference ---');
      final XFile image = await _cameraController!.takePicture();
      final bytes = await image.readAsBytes();

      Size? imageSize;
      img.Image? orientedImage;
      try {
        final decoded = img.decodeImage(bytes);
        if (decoded != null) {
          final oriented = img.bakeOrientation(decoded);
          orientedImage = oriented;
          imageSize =
              Size(oriented.width.toDouble(), oriented.height.toDouble());

          final small = img.copyResize(oriented, width: 150, height: 150);
          final gray = img.grayscale(small);
          double sumLap = 0, sumLapSq = 0;
          int count = 0;
          for (int y = 1; y < gray.height - 1; y++) {
            for (int x = 1; x < gray.width - 1; x++) {
              final c = gray.getPixel(x, y).r.toDouble();
              final t = gray.getPixel(x, y - 1).r.toDouble();
              final b = gray.getPixel(x, y + 1).r.toDouble();
              final l = gray.getPixel(x - 1, y).r.toDouble();
              final rv = gray.getPixel(x + 1, y).r.toDouble();
              final lap = t + b + l + rv - 4 * c;
              sumLap += lap;
              sumLapSq += lap * lap;
              count++;
            }
          }
          if (count > 0) {
            final mean = sumLap / count;
            final blurVariance = (sumLapSq / count) - (mean * mean);
            _addLog("Blur variance: ${blurVariance.toStringAsFixed(1)}");
            if (blurVariance < 150.0 && mounted) {
              await showDialog(
                context: context,
                barrierDismissible: false,
                builder: (_) => AlertDialog(
                  backgroundColor: const Color(0xFF1A1A24),
                  shape: RoundedRectangleBorder(
                      borderRadius: BorderRadius.circular(16)),
                  title: const Row(children: [
                    Icon(Icons.blur_on, color: Color(0xFFDC143C)),
                    SizedBox(width: 8),
                    Text('Image Not Clear',
                        style: TextStyle(color: Colors.white, fontSize: 18)),
                  ]),
                  content: const Text(
                    'The photo appears blurry or out of focus.\nPlease hold the device steady and retake.',
                    style: TextStyle(color: Colors.white70, height: 1.5),
                  ),
                  actions: [
                    ElevatedButton.icon(
                      onPressed: () => Navigator.pop(context),
                      icon: const Icon(Icons.camera_alt,
                          color: Colors.white, size: 18),
                      label: const Text('Retake',
                          style: TextStyle(color: Colors.white)),
                      style: ElevatedButton.styleFrom(
                        backgroundColor: const Color(0xFFDC143C),
                        shape: RoundedRectangleBorder(
                            borderRadius: BorderRadius.circular(8)),
                      ),
                    ),
                  ],
                ),
              );
              return;
            }
          }
        }
      } catch (_) {}

      setState(() {
        _isAnalyzing = true;
        _bestResult = null;
        _capturedImageBytes = bytes;
        _capturedImageSize = imageSize;
      });

      final currentTask = widget.tasks[_currentIndex];
      final List<String> targetClasses =
          List<String>.from(currentTask['classes'] ?? []);
      _addLog("Target: ${targetClasses.join(', ')}");

      final allDetections = orientedImage != null
          ? await ModelManager().predictImage(orientedImage)
          : await ModelManager().predictBytes(bytes);
      setState(() => _allDetections = allDetections);

      String? savedImagePath;
      try {
        final dir = await getApplicationDocumentsDirectory();
        final imgDir = Directory('${dir.path}/inspection_images');
        await imgDir.create(recursive: true);
        savedImagePath =
            '${imgDir.path}/${DateTime.now().millisecondsSinceEpoch}.jpg';
        await File(savedImagePath).writeAsBytes(bytes, flush: true);
        final savedLen = await File(savedImagePath).length();
        _addLog("Image saved: ${savedLen}B -> $savedImagePath");
      } catch (e) {
        _addLog("Image save FAILED: $e");
        savedImagePath = null;
      }

      _addLog("Detections: ${allDetections.length}");
      for (final d in allDetections) {
        _addLog(
            "  ${d.className} ${(d.confidence * 100).toStringAsFixed(1)}%");
      }

      final filtered = allDetections
          .where((d) => targetClasses.any((tc) =>
              d.className.toLowerCase().trim() == tc.toLowerCase().trim()))
          .toList();
      _addLog("Matched target: ${filtered.length}");

      setState(() {
        if (filtered.isNotEmpty) {
          filtered.sort((a, b) => b.confidence.compareTo(a.confidence));
          _bestResult = filtered.first;
          final pass = _isPass(_bestResult!.className, targetClasses);
          _addLog("WINNER: ${_bestResult!.className} | pass=$pass");

          _results[_currentIndex] = {
            'className': _bestResult!.className,
            'success': pass,
            'imagePath': savedImagePath,
            'detectionsJson': jsonEncode([_bestResult!.toJson()]),
          };
        } else {
          // Keep only the single best non-target detection.
          // Taking more than 1 caused repeated rows of the same class
          // (e.g. "not ok 85%, not ok 72%, not ok 63%") which confused users.
          final nonTarget = List<DetectionResult>.from(allDetections)
            ..sort((a, b) => b.confidence.compareTo(a.confidence));
          _detectedNonTargetClasses = nonTarget.take(1).toList();
          final bestDetected = _detectedNonTargetClasses.isNotEmpty
              ? _detectedNonTargetClasses.first
              : null;
          _addLog("NON-TARGET: ${bestDetected?.className ?? 'nothing'}");

          _results[_currentIndex] = {
            'className': bestDetected?.className ?? 'None',
            'success': false,
            'imagePath': savedImagePath,
            'detectionsJson': bestDetected != null
                ? jsonEncode([bestDetected.toJson()])
                : jsonEncode([]),
          };
        }
        _isAnalyzing = false;
      });
    } catch (e) {
      _addLog("ERROR: $e");
      setState(() => _isAnalyzing = false);
      if (mounted) {
        ScaffoldMessenger.of(context)
            .showSnackBar(SnackBar(content: Text('Capture failed: $e')));
      }
    }
  }

  Future<void> _toggleFlash() async {
    if (_cameraController == null || !_isCameraInitialized) return;
    final newOn = !_isFlashOn;
    try {
      await _cameraController!
          .setFlashMode(newOn ? FlashMode.torch : FlashMode.off);
      setState(() => _isFlashOn = newOn);
      _addLog(newOn ? 'Flash ON' : 'Flash OFF');
    } catch (e) {
      _addLog("Flash error: $e");
    }
  }

  void _retake() {
    _addLog('Retake');
    setState(() {
      _capturedImageBytes = null;
      _capturedImageSize = null;
      _bestResult = null;
      _isAnalyzing = false;
      _allDetections = [];
      _detectedNonTargetClasses = [];
    });
  }

  void _onSaveAndContinue() {
    _results[_currentIndex] ??= {
      'className': 'None',
      'success': false,
      'imagePath': null,
      'detectionsJson': jsonEncode([]),
    };

    if (_results.length == widget.tasks.length) {
      _addLog('All tasks done');
      Navigator.pop(context, _results);
      return;
    }

    final nextIdx = (_currentIndex + 1) % widget.tasks.length;
    _addLog("Moving to Task ${nextIdx + 1}");
    setState(() {
      _currentIndex = nextIdx;
      _capturedImageBytes = null;
      _bestResult = null;
      _detectedNonTargetClasses = [];
    });
    _loadCurrentModel();
  }

  @override
  Widget build(BuildContext context) {
    if (_error != null) {
      return Scaffold(body: Center(child: Text('Error: $_error')));
    }
    final currentTask = widget.tasks[_currentIndex];
    final List<String> taskClasses =
        List<String>.from(currentTask['classes'] ?? []);

    final bool badgeGreen =
        _bestResult != null && _isPass(_bestResult!.className, taskClasses);

    final DetectionResult? overlayResult = _bestResult ??
        (_detectedNonTargetClasses.isNotEmpty
            ? _detectedNonTargetClasses.first
            : null);

    return Scaffold(
      body: Container(
        decoration: const BoxDecoration(
          gradient: LinearGradient(
            begin: Alignment.topCenter,
            end: Alignment.bottomCenter,
            colors: [Colors.white, Color(0xFFFFF5F5)],
          ),
        ),
        child: SafeArea(
          child: Column(
            children: [
              Container(
                width: double.infinity,
                padding:
                    const EdgeInsets.symmetric(vertical: 12, horizontal: 16),
                decoration: const BoxDecoration(color: Color(0xFFDC143C)),
                child: Row(
                  children: [
                    IconButton(
                      icon: const Icon(Icons.arrow_back, color: Colors.white),
                      onPressed: () => Navigator.pop(context, _results),
                    ),
                    Expanded(
                      child: Center(
                        child: Column(
                          mainAxisSize: MainAxisSize.min,
                          children: [
                            Text(
                              'TASK ${_currentIndex + 1} OF ${widget.tasks.length}',
                              style: const TextStyle(
                                  color: Colors.white,
                                  fontSize: 14,
                                  fontWeight: FontWeight.bold),
                            ),
                            Text(
                              'VIN: ${widget.vin}',
                              style: const TextStyle(
                                  color: Colors.white70, fontSize: 10),
                            ),
                          ],
                        ),
                      ),
                    ),
                    IconButton(
                      icon: Icon(
                        _showDebugConsole
                            ? Icons.bug_report
                            : Icons.bug_report_outlined,
                        color: Colors.white70,
                      ),
                      onPressed: () => setState(
                          () => _showDebugConsole = !_showDebugConsole),
                    ),
                  ],
                ),
              ),
              Container(
                width: double.infinity,
                padding:
                    const EdgeInsets.symmetric(vertical: 12, horizontal: 16),
                color: Colors.white.withOpacity(0.9),
                child: Column(
                  children: [
                    Text(
                      currentTask['name'] as String,
                      style: const TextStyle(
                          color: Color(0xFFDC143C),
                          fontWeight: FontWeight.w900,
                          fontSize: 18),
                    ),
                    const SizedBox(height: 4),
                    const Text(
                      'Align object within the frame and capture',
                      style: TextStyle(color: Colors.grey, fontSize: 12),
                    ),
                  ],
                ),
              ),
              Expanded(
                child: Stack(
                  children: [
                    if (_capturedImageBytes == null)
                      Positioned.fill(
                        child: _isCameraInitialized && _cameraController != null
                            ? CameraPreview(_cameraController!)
                            : const Center(
                                child: CircularProgressIndicator(
                                    color: Color(0xFFDC143C))),
                      ),
                    if (_capturedImageBytes != null)
                      Positioned.fill(
                        child: _capturedImageSize != null
                            ? FittedBox(
                                fit: BoxFit.contain,
                                child: SizedBox(
                                  width: _capturedImageSize!.width,
                                  height: _capturedImageSize!.height,
                                  child: Stack(
                                    fit: StackFit.expand,
                                    children: [
                                      Image.memory(
                                        _capturedImageBytes!,
                                        fit: BoxFit.fill,
                                        width: _capturedImageSize!.width,
                                        height: _capturedImageSize!.height,
                                      ),
                                      if (overlayResult != null)
                                        DetectionOverlay(
                                          results: [overlayResult],
                                          previewSize: _capturedImageSize!,
                                          overrideColor: badgeGreen
                                              ? Colors.green
                                              : Colors.red,
                                        ),
                                    ],
                                  ),
                                ),
                              )
                            : Image.memory(_capturedImageBytes!,
                                fit: BoxFit.contain),
                      ),
                    if (_capturedImageBytes == null)
                      Center(
                        child: Container(
                          width: 280,
                          height: 280,
                          decoration: BoxDecoration(
                            border: Border.all(
                                color: const Color(0xFFDC143C), width: 2),
                          ),
                        ),
                      ),
                    if (_isLoadingModel && _capturedImageBytes == null)
                      Container(
                        color: Colors.black45,
                        child: const Center(
                            child: CircularProgressIndicator(
                                color: Colors.white)),
                      ),
                    if (_isAnalyzing)
                      Container(
                        color: Colors.black54,
                        child: const Center(
                            child: CircularProgressIndicator(
                                color: Color(0xFFDC143C))),
                      ),
                    if (_capturedImageBytes == null && _isCameraInitialized)
                      Positioned(
                        top: 16,
                        left: 16,
                        child: GestureDetector(
                          onTap: _toggleFlash,
                          child: Container(
                            width: 48,
                            height: 48,
                            decoration: BoxDecoration(
                              color: _isFlashOn
                                  ? const Color(0xFFFFD700)
                                  : Colors.black54,
                              shape: BoxShape.circle,
                              border: Border.all(
                                color: _isFlashOn
                                    ? const Color(0xFFFFD700)
                                    : Colors.white30,
                                width: 1.5,
                              ),
                            ),
                            child: Icon(
                              _isFlashOn
                                  ? Icons.flashlight_on
                                  : Icons.flashlight_off,
                              color:
                                  _isFlashOn ? Colors.black : Colors.white,
                              size: 24,
                            ),
                          ),
                        ),
                      ),
                    if (!_isAnalyzing && _capturedImageBytes != null)
                      Positioned(
                        top: 16,
                        right: 16,
                        child: Container(
                          padding: const EdgeInsets.symmetric(
                              horizontal: 16, vertical: 8),
                          decoration: BoxDecoration(
                            color: badgeGreen ? Colors.green : Colors.red,
                            borderRadius: BorderRadius.circular(20),
                          ),
                          child: Text(
                            badgeGreen
                                ? '✓ ${_bestResult!.className}'
                                : overlayResult != null
                                    ? '✗ ${overlayResult.className}'
                                    : 'NOT FOUND',
                            style: const TextStyle(
                                color: Colors.white,
                                fontWeight: FontWeight.bold,
                                fontSize: 13),
                          ),
                        ),
                      ),
                    if (!_isAnalyzing &&
                        _capturedImageBytes != null &&
                        _bestResult == null &&
                        !_showDebugConsole)
                      Positioned(
                        bottom: 0,
                        left: 0,
                        right: 0,
                        child: Container(
                          padding:
                              const EdgeInsets.fromLTRB(16, 14, 16, 14),
                          decoration: BoxDecoration(
                            color: Colors.black.withOpacity(0.88),
                            borderRadius: const BorderRadius.vertical(
                                top: Radius.circular(16)),
                          ),
                          child: Column(
                            mainAxisSize: MainAxisSize.min,
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              Row(children: [
                                const Icon(Icons.cancel,
                                    color: Colors.red, size: 16),
                                const SizedBox(width: 6),
                                Expanded(
                                  child: Text(
                                    "Target not found: ${taskClasses.join(', ')}",
                                    style: const TextStyle(
                                        color: Colors.red,
                                        fontWeight: FontWeight.bold,
                                        fontSize: 13),
                                    overflow: TextOverflow.ellipsis,
                                  ),
                                ),
                              ]),
                              if (_detectedNonTargetClasses.isNotEmpty) ...[
                                const SizedBox(height: 10),
                                const Text('Detected instead:',
                                    style: TextStyle(
                                        color: Colors.white54,
                                        fontSize: 11)),
                                const SizedBox(height: 6),
                                ..._detectedNonTargetClasses
                                    .map((d) => Padding(
                                          padding: const EdgeInsets.only(
                                              bottom: 4),
                                          child: Row(children: [
                                            const Icon(Icons.close,
                                                color: Colors.orange,
                                                size: 14),
                                            const SizedBox(width: 6),
                                            Text(
                                              d.className,
                                              style: const TextStyle(
                                                  color: Colors.orange,
                                                  fontSize: 13,
                                                  fontWeight:
                                                      FontWeight.w600),
                                            ),
                                            const SizedBox(width: 8),
                                            Text(
                                              "${(d.confidence * 100).toStringAsFixed(0)}%",
                                              style: const TextStyle(
                                                  color: Colors.white54,
                                                  fontSize: 12),
                                            ),
                                          ]),
                                        )),
                              ] else ...[
                                const SizedBox(height: 8),
                                const Text('Nothing detected.',
                                    style: TextStyle(
                                        color: Colors.white54,
                                        fontSize: 12)),
                              ],
                            ],
                          ),
                        ),
                      ),
                    if (_showDebugConsole)
                      Positioned(
                        bottom: 0,
                        left: 0,
                        right: 0,
                        height: 200,
                        child: Container(
                          color: Colors.black.withOpacity(0.85),
                          padding: const EdgeInsets.all(8),
                          child: Column(
                            crossAxisAlignment: CrossAxisAlignment.start,
                            children: [
                              Row(
                                mainAxisAlignment:
                                    MainAxisAlignment.spaceBetween,
                                children: [
                                  const Text('DEBUG CONSOLE',
                                      style: TextStyle(
                                          color: Colors.yellow,
                                          fontWeight: FontWeight.bold,
                                          fontSize: 10)),
                                  IconButton(
                                    icon: const Icon(Icons.delete_sweep,
                                        color: Colors.white, size: 16),
                                    onPressed: () =>
                                        setState(() => _debugLogs = []),
                                    padding: EdgeInsets.zero,
                                    constraints: const BoxConstraints(),
                                  ),
                                ],
                              ),
                              const Divider(color: Colors.white24),
                              Expanded(
                                child: ListView.builder(
                                  itemCount: _debugLogs.length,
                                  itemBuilder: (_, idx) => Padding(
                                    padding:
                                        const EdgeInsets.only(bottom: 2),
                                    child: Text(
                                      _debugLogs[idx],
                                      style: const TextStyle(
                                          color: Colors.white,
                                          fontFamily: 'monospace',
                                          fontSize: 9),
                                    ),
                                  ),
                                ),
                              ),
                            ],
                          ),
                        ),
                      ),
                  ],
                ),
              ),
              Padding(
                padding: const EdgeInsets.all(24),
                child: _capturedImageBytes == null
                    ? GestureDetector(
                        onTap: (_isLoadingModel ||
                                _isAnalyzing ||
                                !_isCameraInitialized)
                            ? null
                            : _handleCapture,
                        child: Container(
                          width: 80,
                          height: 80,
                          decoration: BoxDecoration(
                            color: const Color(0xFFDC143C),
                            shape: BoxShape.circle,
                            boxShadow: const [
                              BoxShadow(
                                  color: Colors.black26,
                                  blurRadius: 10,
                                  offset: Offset(0, 4))
                            ],
                          ),
                          child: const Icon(Icons.camera_alt,
                              color: Colors.white, size: 40),
                        ),
                      )
                    : Row(
                        children: [
                          Expanded(
                            child: OutlinedButton(
                              onPressed: _retake,
                              style: OutlinedButton.styleFrom(
                                padding: const EdgeInsets.symmetric(
                                    vertical: 16),
                                side: const BorderSide(
                                    color: Color(0xFFDC143C)),
                              ),
                              child: const Text('RETAKE',
                                  style: TextStyle(
                                      color: Color(0xFFDC143C),
                                      fontWeight: FontWeight.bold)),
                            ),
                          ),
                          const SizedBox(width: 16),
                          Expanded(
                            child: ElevatedButton(
                              onPressed: _onSaveAndContinue,
                              style: ElevatedButton.styleFrom(
                                backgroundColor: Colors.green,
                                padding: const EdgeInsets.symmetric(
                                    vertical: 16),
                              ),
                              child: Text(
                                _results.length + 1 == widget.tasks.length
                                    ? 'FINISH'
                                    : 'NEXT TASK',
                                style: const TextStyle(
                                    color: Colors.white,
                                    fontWeight: FontWeight.bold),
                              ),
                            ),
                          ),
                        ],
                      ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}
