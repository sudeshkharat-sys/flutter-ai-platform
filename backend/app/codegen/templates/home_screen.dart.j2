import 'package:camera/camera.dart';
import 'package:flutter/material.dart';
import 'dart:convert';
import 'package:flutter/services.dart';
import 'package:shared_preferences/shared_preferences.dart';
import 'package:drift/drift.dart' as drift;
import 'inspection_camera_screen.dart';
import 'history_screen.dart';
import '../services/print_service.dart';
import '../database/database.dart';

class HomeScreen extends StatefulWidget {
  final List<CameraDescription> cameras;
  final String? vin;
  final String? modelCode;
  const HomeScreen({super.key, required this.cameras, this.vin, this.modelCode});

  @override
  State<HomeScreen> createState() => _HomeScreenState();
}

class _HomeScreenState extends State<HomeScreen> {
  List<dynamic> _tasks = [];
  Map<int, dynamic> _taskResults = {}; // Index -> DetectionResult
  bool _loading = true;

  void _showReferenceImage(BuildContext context, String assetPath) {
    showDialog(
      context: context,
      builder: (ctx) => Dialog(
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Container(
              padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 12),
              decoration: const BoxDecoration(
                color: Color(0xFFDC143C),
                borderRadius: BorderRadius.only(topLeft: Radius.circular(16), topRight: Radius.circular(16)),
              ),
              child: Row(
                children: [
                  const Expanded(
                    child: Text('Reference Image', style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold, fontSize: 15)),
                  ),
                  IconButton(
                    icon: const Icon(Icons.close, color: Colors.white, size: 20),
                    padding: EdgeInsets.zero,
                    constraints: const BoxConstraints(),
                    onPressed: () => Navigator.pop(ctx),
                  ),
                ],
              ),
            ),
            ClipRRect(
              borderRadius: const BorderRadius.only(bottomLeft: Radius.circular(16), bottomRight: Radius.circular(16)),
              child: Image.asset(
                assetPath,
                fit: BoxFit.contain,
                errorBuilder: (_, __, ___) => const Padding(
                  padding: EdgeInsets.all(32),
                  child: Text('Image not available', style: TextStyle(color: Colors.grey)),
                ),
              ),
            ),
          ],
        ),
      ),
    );
  }

  @override
  void initState() {
    super.initState();
    _loadTasksAndProgress();
  }

  Future<void> _loadTasksAndProgress() async {
    try {
      // 1. Load tasks from manifest
      final String manifestStr = await rootBundle.loadString('assets/models_manifest.json');
      final List<dynamic> manifest = json.decode(manifestStr);
      
      final List<dynamic> filtered = manifest.where((task) {
        if (widget.modelCode == null || widget.modelCode!.isEmpty) return true;
        return task['vehicle_code'] == widget.modelCode;
      }).toList();

      // 2. Load existing progress from local DB for this VIN
      if (widget.vin != null) {
        final existingResults = await db.getLatestResultsForVin(widget.vin!);
        final Map<int, dynamic> restored = {};
        
        for (var res in existingResults) {
          // Try to match by task name
          final idx = filtered.indexWhere((t) => t['name'] == res.taskName);
          if (idx != -1) {
            restored[idx] = {
              'className': res.className,
              'success': res.success,
              'imagePath': res.imagePath,
              'detectionsJson': res.detectionsJson,
            };
          }
        }
        _taskResults = restored;
      }

      setState(() {
        _tasks = filtered;
        _loading = false;
      });
    } catch (e) {
      setState(() => _loading = false);
      debugPrint("Load error: $e");
    }
  }

  void _submitInspection() async {
    if (_taskResults.length < _tasks.length) {
      showDialog(
        context: context,
        builder: (context) => AlertDialog(
          title: const Text("Incomplete Inspection"),
          content: Text("Please complete all ${_tasks.length} tasks before submitting."),
          actions: [
            TextButton(onPressed: () => Navigator.pop(context), child: const Text("OK")),
          ],
        ),
      );
      return;
    }

    // Show confirmation modal with task summary
    final bool? confirmed = await showDialog<bool>(
      context: context,
      barrierDismissible: false,
      builder: (context) => _buildSubmitConfirmDialog(),
    );

    if (confirmed != true) return;

    // Persist to local DB
    final inspectionId = await db.saveInspection(InspectionsCompanion.insert(
      vin: widget.vin ?? 'UNKNOWN',
      modelCode: widget.modelCode ?? 'UNKNOWN',
    ));

    for (int i = 0; i < _tasks.length; i++) {
      final task = _tasks[i];
      final result = _taskResults[i];
      final success = result['success'] ?? false;

      await db.saveTaskResult(TaskResultsCompanion.insert(
        inspectionId: inspectionId,
        taskName: task['name'],
        className: result['className'] ?? 'None',
        confidence: 0.0,
        success: success,
        imagePath: drift.Value(result['imagePath'] as String?),
        detectionsJson: drift.Value(result['detectionsJson'] as String?),
      ));
    }

    if (!mounted) return;
    ScaffoldMessenger.of(context).showSnackBar(
      const SnackBar(content: Text("Inspection Persisted to Local Database!"), backgroundColor: Colors.green),
    );

    // Build task list for printing
    final printTasks = List.generate(_tasks.length, (i) {
      final result = _taskResults[i] ?? {};
      return {
        'taskName': _tasks[i]['name'] as String? ?? 'Task',
        'success': result['success'] as bool? ?? false,
        'detectedPart': result['className'] as String?,
      };
    });

    // Auto-print to the first paired Bluetooth printer
    final printers = await PrintService.instance.getBondedPrinters();
    if (!mounted) return;

    if (printers.isEmpty) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text("No paired printer found. Please pair a Bluetooth printer in device settings."),
          backgroundColor: Colors.orange,
          duration: Duration(seconds: 4),
        ),
      );
    } else {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text("Printing to ${printers.first.name}..."),
          backgroundColor: Colors.blue,
          duration: const Duration(seconds: 2),
        ),
      );
      final printSuccess = await PrintService.instance.printInspectionReport(
        printer: printers.first,
        vin: widget.vin ?? 'UNKNOWN',
        modelCode: widget.modelCode ?? 'UNKNOWN',
        timestamp: DateTime.now().toIso8601String(),
        overallSuccess: _taskResults.values.every((r) => r['success'] == true),
        tasks: printTasks,
      );
      if (!mounted) return;
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(printSuccess
              ? "Report printed to ${printers.first.name}"
              : "Print failed. Please check the printer."),
          backgroundColor: printSuccess ? Colors.green : Colors.red,
        ),
      );
    }

    if (mounted) Navigator.pop(context);
  }

  Widget _buildSubmitConfirmDialog() {
    final bool allOk = _taskResults.values.every((r) => r['success'] == true);
    final int failCount = _taskResults.values.where((r) => r['success'] != true).length;

    return Dialog(
      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(16)),
      child: Padding(
        padding: const EdgeInsets.all(24),
        child: Column(
          mainAxisSize: MainAxisSize.min,
          crossAxisAlignment: CrossAxisAlignment.start,
          children: [
            // Title row
            Row(
              children: [
                Icon(
                  allOk ? Icons.check_circle_outline : Icons.warning_amber_rounded,
                  color: allOk ? Colors.green : Colors.orange,
                  size: 26,
                ),
                const SizedBox(width: 10),
                const Text(
                  'Submit Inspection',
                  style: TextStyle(fontSize: 18, fontWeight: FontWeight.bold),
                ),
              ],
            ),
            const SizedBox(height: 16),
            const Divider(),
            const SizedBox(height: 8),

            // Per-task summary -- scrollable so it never overflows
            Flexible(
              child: SingleChildScrollView(
                child: Column(
                  mainAxisSize: MainAxisSize.min,
                  children: List.generate(_tasks.length, (i) {
                    final ok = _taskResults[i]?['success'] == true;
                    return Padding(
                      padding: const EdgeInsets.symmetric(vertical: 5),
                      child: Row(
                        children: [
                          Icon(
                            ok ? Icons.check_circle : Icons.cancel,
                            color: ok ? Colors.green : Colors.red,
                            size: 20,
                          ),
                          const SizedBox(width: 10),
                          Expanded(
                            child: Text(
                              _tasks[i]['name'],
                              style: TextStyle(
                                fontSize: 14,
                                fontWeight: FontWeight.w500,
                                color: ok ? Colors.black87 : Colors.red[700],
                              ),
                            ),
                          ),
                          Container(
                            padding: const EdgeInsets.symmetric(horizontal: 8, vertical: 3),
                            decoration: BoxDecoration(
                              color: ok
                                  ? Colors.green.withOpacity(0.12)
                                  : Colors.red.withOpacity(0.12),
                              borderRadius: BorderRadius.circular(6),
                            ),
                            child: Text(
                              ok ? 'OK' : 'NOT OK',
                              style: TextStyle(
                                fontSize: 11,
                                fontWeight: FontWeight.bold,
                                color: ok ? Colors.green[700] : Colors.red[700],
                              ),
                            ),
                          ),
                        ],
                      ),
                    );
                  }),
                ),
              ),
            ),

            const SizedBox(height: 12),
            const Divider(),
            const SizedBox(height: 10),

            // Summary message
            Text(
              allOk
                  ? 'All targets found. Are you sure you want to submit?'
                  : '$failCount task${failCount > 1 ? 's' : ''} did not find the target. Are you sure you want to submit anyway?',
              style: TextStyle(
                fontSize: 13,
                color: allOk ? Colors.black54 : Colors.orange[800],
                fontWeight: FontWeight.w500,
              ),
            ),

            const SizedBox(height: 20),

            // Action buttons
            Row(
              children: [
                Expanded(
                  child: OutlinedButton(
                    onPressed: () => Navigator.pop(context, false),
                    style: OutlinedButton.styleFrom(
                      padding: const EdgeInsets.symmetric(vertical: 14),
                      side: const BorderSide(color: Color(0xFFDC143C)),
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8)),
                    ),
                    child: const Text(
                      'CANCEL',
                      style: TextStyle(color: Color(0xFFDC143C), fontWeight: FontWeight.bold),
                    ),
                  ),
                ),
                const SizedBox(width: 12),
                Expanded(
                  child: ElevatedButton(
                    onPressed: () => Navigator.pop(context, true),
                    style: ElevatedButton.styleFrom(
                      backgroundColor: const Color(0xFFDC143C),
                      padding: const EdgeInsets.symmetric(vertical: 14),
                      shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(8)),
                    ),
                    child: const Text(
                      'SUBMIT',
                      style: TextStyle(color: Colors.white, fontWeight: FontWeight.bold),
                    ),
                  ),
                ),
              ],
            ),
          ],
        ),
      ),
    );
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFFFF5F5),
      body: Column(
        children: [
          // Top Header
          Container(
            width: double.infinity,
            padding: const EdgeInsets.symmetric(vertical: 12, horizontal: 16),
            decoration: const BoxDecoration(color: Color(0xFFDC143C)),
            child: SafeArea(
              bottom: false,
              child: Row(
                children: [
                  IconButton(
                    icon: const Icon(Icons.arrow_back, color: Colors.white),
                    onPressed: () => Navigator.pop(context),
                  ),
                  const Spacer(),
                  const Text(
                    'INSPECTION',
                    style: TextStyle(
                      color: Colors.white,
                      fontSize: 18,
                      fontWeight: FontWeight.bold,
                      letterSpacing: 1.5,
                    ),
                  ),
                  const Spacer(),
                  const SizedBox(width: 48), 
                ],
              ),
            ),
          ),

          // Vehicle Info Bar
          Container(
            width: double.infinity,
            padding: const EdgeInsets.all(16),
            decoration: BoxDecoration(
              color: Colors.white.withOpacity(0.9),
              border: const Border(
                top: BorderSide(color: Color(0xFFD4AF37), width: 1),
                bottom: BorderSide(color: Color(0xFFD4AF37), width: 1),
              ),
            ),
            child: Column(
              children: [
                Text(
                  'VIN: ${widget.vin ?? "N/A"}',
                  style: const TextStyle(
                    color: Color(0xFFDC143C),
                    fontSize: 16,
                    fontWeight: FontWeight.bold,
                  ),
                ),
                const SizedBox(height: 4),
                Text(
                  'Model Code: ${widget.modelCode ?? "N/A"}',
                  style: const TextStyle(
                    color: Colors.black87,
                    fontSize: 13,
                    fontWeight: FontWeight.w500,
                  ),
                ),
              ],
            ),
          ),

          // Task List
          Expanded(
            child: _loading 
              ? const Center(child: CircularProgressIndicator(color: Color(0xFFDC143C)))
              : ListView.builder(
                  padding: const EdgeInsets.all(16),
                  itemCount: _tasks.length,
                  itemBuilder: (context, index) {
                    final task = _tasks[index];
                    final bool isDone = _taskResults.containsKey(index);
                    
                    return Container(
                      margin: const EdgeInsets.only(bottom: 12),
                      child: ElevatedButton(
                        onPressed: () async {
                          final result = await Navigator.push(
                            context,
                            MaterialPageRoute(
                              builder: (context) => InspectionCameraScreen(
                                vin: widget.vin ?? "MANUAL_SCAN",
                                modelCode: widget.modelCode ?? "", 
                                tasks: _tasks,
                                initialIndex: index,
                              ),
                            ),
                          );
                          
                          if (result != null && result is Map<int, dynamic>) {
                            setState(() {
                              _taskResults.addAll(result);
                            });
                          }
                        },
                        style: ElevatedButton.styleFrom(
                          backgroundColor: Colors.white,
                          foregroundColor: const Color(0xFFDC143C),
                          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 16),
                          shape: RoundedRectangleBorder(
                            borderRadius: BorderRadius.circular(8),
                            side: BorderSide(
                              color: !isDone
                                  ? const Color(0xFFD4AF37)
                                  : (_taskResults[index]?['success'] == true ? Colors.green : Colors.red),
                              width: isDone ? 2 : 1,
                            ),
                          ),
                          elevation: 0,
                        ),
                        child: Row(
                          mainAxisAlignment: MainAxisAlignment.spaceBetween,
                          children: [
                            Expanded(
                              child: Text(
                                task['name'],
                                style: TextStyle(
                                  fontSize: 16,
                                  fontWeight: FontWeight.w500,
                                  color: !isDone
                                      ? const Color(0xFFDC143C)
                                      : (_taskResults[index]?['success'] == true
                                          ? Colors.green[700]
                                          : Colors.red[700]),
                                ),
                              ),
                            ),
                            if (task['reference_image'] != null)
                              GestureDetector(
                                onTap: () => _showReferenceImage(context, task['reference_image']),
                                child: Container(
                                  margin: const EdgeInsets.only(right: 8),
                                  padding: const EdgeInsets.all(4),
                                  decoration: BoxDecoration(
                                    color: const Color(0xFFD4AF37).withOpacity(0.15),
                                    shape: BoxShape.circle,
                                  ),
                                  child: const Icon(Icons.remove_red_eye_outlined, size: 18, color: Color(0xFFD4AF37)),
                                ),
                              ),
                            if (isDone)
                              Icon(
                                _taskResults[index]?['success'] == true
                                    ? Icons.check_circle
                                    : Icons.cancel,
                                color: _taskResults[index]?['success'] == true
                                    ? Colors.green
                                    : Colors.red,
                              )
                            else
                              const Icon(Icons.camera_alt, size: 20, color: Color(0xFFDC143C)),
                          ],
                        ),
                      ),
                    );
                  },
                ),
          ),
          
          // Submit Button
          if (_tasks.isNotEmpty)
            Padding(
              padding: const EdgeInsets.all(24),
              child: SizedBox(
                width: double.infinity,
                child: ElevatedButton(
                  onPressed: _submitInspection,
                  style: ElevatedButton.styleFrom(
                    backgroundColor: const Color(0xFFDC143C),
                    foregroundColor: Colors.white,
                    padding: const EdgeInsets.symmetric(vertical: 18),
                    shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(12)),
                    elevation: 4,
                  ),
                  child: const Text('SUBMIT INSPECTION', style: TextStyle(fontSize: 16, fontWeight: FontWeight.bold, letterSpacing: 1.2)),
                ),
              ),
            ),
        ],
      ),
      bottomNavigationBar: _buildBottomNav(),
    );
  }

  Widget _buildBottomNav() {
    return Container(
      height: 80,
      decoration: BoxDecoration(
        color: Colors.white,
        borderRadius: const BorderRadius.only(topLeft: Radius.circular(20), topRight: Radius.circular(20)),
        boxShadow: [BoxShadow(color: Colors.black.withOpacity(0.1), blurRadius: 10, offset: const Offset(0, -2))],
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceAround,
        children: [
          _navItem(Icons.home, "Home", true),
          _navItem(Icons.history, "History", false, onTap: () {
            Navigator.push(context, MaterialPageRoute(builder: (_) => const HistoryScreen()));
          }),
        ],
      ),
    );
  }

  Widget _navItem(IconData icon, String label, bool active, {VoidCallback? onTap}) {
    final color = active ? const Color(0xFFDC143C) : Colors.grey;
    return InkWell(
      onTap: onTap,
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          Icon(icon, color: color),
          Text(label, style: TextStyle(color: color, fontSize: 12)),
        ],
      ),
    );
  }
}
