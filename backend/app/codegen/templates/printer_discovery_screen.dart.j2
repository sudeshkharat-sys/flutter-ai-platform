import 'package:flutter/material.dart';
import 'package:permission_handler/permission_handler.dart';
import '../services/print_service.dart';

const _crimson = Color(0xFFDC143C);
const _crimsonLight = Color(0xFFFFEBEE);
const _crimsonDark = Color(0xFFB01030);

class PrinterDiscoveryScreen extends StatefulWidget {
  final String vin;
  final String modelCode;
  final String timestamp;
  final bool overallSuccess;
  final List<Map<String, dynamic>> tasks;

  const PrinterDiscoveryScreen({
    super.key,
    required this.vin,
    required this.modelCode,
    required this.timestamp,
    required this.overallSuccess,
    required this.tasks,
  });

  @override
  State<PrinterDiscoveryScreen> createState() =>
      _PrinterDiscoveryScreenState();
}

class _PrinterDiscoveryScreenState extends State<PrinterDiscoveryScreen> {
  final List<DiscoveredPrinter> _printers = [];
  bool _scanning = false;
  bool _printing = false;
  String _statusMessage = '';
  final TextEditingController _macController = TextEditingController();

  @override
  void initState() {
    super.initState();
    _loadBondedDevices();
  }

  @override
  void dispose() {
    _macController.dispose();
    super.dispose();
  }

  /// Request BLUETOOTH_CONNECT + BLUETOOTH_SCAN at runtime (Android 12+).
  /// Returns true if permissions are granted.
  Future<bool> _ensureBluetoothPermissions() async {
    final statuses = await [
      Permission.bluetoothConnect,
      Permission.bluetoothScan,
    ].request();

    final connectGranted =
        statuses[Permission.bluetoothConnect]?.isGranted ?? false;
    final scanGranted =
        statuses[Permission.bluetoothScan]?.isGranted ?? false;

    if (!connectGranted || !scanGranted) {
      if (mounted) {
        setState(() {
          _scanning = false;
          _statusMessage =
              'Bluetooth permission denied. Grant it in App Settings.';
        });
        ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(
            content: const Text(
                'Bluetooth permission is required to find printers.'),
            backgroundColor: _crimson,
            action: SnackBarAction(
              label: 'Settings',
              textColor: Colors.white,
              onPressed: openAppSettings,
            ),
          ),
        );
      }
      return false;
    }
    return true;
  }

  Future<void> _loadBondedDevices() async {
    setState(() {
      _printers.clear();
      _scanning = true;
      _statusMessage = 'Loading paired devices…';
    });

    if (!await _ensureBluetoothPermissions()) return;

    final bonded = await PrintService.instance.getBondedPrinters();

    if (mounted) {
      setState(() {
        _printers.addAll(bonded);
        _scanning = false;
        _statusMessage = bonded.isEmpty
            ? 'No paired devices found'
            : '${bonded.length} paired device(s)';
      });
    }
  }

  Future<void> _discoverPrinters() async {
    setState(() {
      _printers.clear();
      _scanning = true;
      _statusMessage = 'Scanning for Zebra printers…';
    });

    if (!await _ensureBluetoothPermissions()) return;

    final found = await PrintService.instance.discoverBluetoothPrinters();

    if (mounted) {
      setState(() {
        _printers.addAll(found);
        _scanning = false;
        _statusMessage = found.isEmpty
            ? 'No printers found. Try pairing first.'
            : '${found.length} printer(s) found';
      });
    }
  }

  void _addManualMac() {
    final mac = _macController.text.trim().toUpperCase();
    if (mac.isEmpty) return;

    final macRegex = RegExp(r'^([0-9A-F]{2}:){5}[0-9A-F]{2}$');
    if (!macRegex.hasMatch(mac)) {
      ScaffoldMessenger.of(context).showSnackBar(
        const SnackBar(
          content: Text('Enter a valid MAC address (e.g. C4:D3:6A:AC:F0:AE)'),
          backgroundColor: _crimson,
        ),
      );
      return;
    }

    setState(() {
      if (!_printers.any((p) => p.address == mac)) {
        _printers.add(DiscoveredPrinter(name: 'Printer @ $mac', address: mac));
      }
    });
    _macController.clear();
    FocusScope.of(context).unfocus();
  }

  Future<void> _printTo(DiscoveredPrinter printer) async {
    setState(() => _printing = true);

    final ok = await PrintService.instance.printInspectionReport(
      printer: printer,
      vin: widget.vin,
      modelCode: widget.modelCode,
      timestamp: widget.timestamp,
      overallSuccess: widget.overallSuccess,
      tasks: widget.tasks,
    );

    if (!mounted) return;
    setState(() => _printing = false);

    ScaffoldMessenger.of(context).showSnackBar(SnackBar(
      content: Text(ok
          ? 'Report printed successfully!'
          : 'Print failed. Ensure printer is paired and in range.'),
      backgroundColor: ok ? Colors.green[700] : _crimson,
    ));

    if (ok && mounted) Navigator.of(context).pop();
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      backgroundColor: const Color(0xFFFFF5F5),
      appBar: AppBar(
        backgroundColor: _crimson,
        title: const Text('Print Report',
            style: TextStyle(color: Colors.white, fontSize: 16, fontWeight: FontWeight.w600)),
        iconTheme: const IconThemeData(color: Colors.white),
        elevation: 0,
      ),
      body: _printing
          ? Center(
              child: Column(
                mainAxisSize: MainAxisSize.min,
                children: [
                  const CircularProgressIndicator(color: _crimson),
                  const SizedBox(height: 16),
                  Text('Sending to printer…',
                      style: TextStyle(color: Colors.grey[700], fontSize: 14)),
                ],
              ),
            )
          : Column(
              children: [
                // ── Status bar ────────────────────────────────────────────────
                Container(
                  padding: const EdgeInsets.symmetric(
                      horizontal: 16, vertical: 10),
                  color: Colors.white,
                  child: Row(
                    children: [
                      if (_scanning)
                        const SizedBox(
                          width: 14,
                          height: 14,
                          child: CircularProgressIndicator(
                              strokeWidth: 2, color: _crimson),
                        )
                      else
                        const Icon(Icons.bluetooth,
                            size: 16, color: _crimson),
                      const SizedBox(width: 10),
                      Expanded(
                        child: Text(
                          _statusMessage,
                          style: TextStyle(
                              color: Colors.grey[700], fontSize: 13),
                        ),
                      ),
                      TextButton.icon(
                        onPressed: _scanning ? null : _loadBondedDevices,
                        icon: const Icon(Icons.bluetooth_connected,
                            size: 14, color: _crimson),
                        label: const Text('Paired',
                            style: TextStyle(color: _crimson, fontSize: 12)),
                        style: TextButton.styleFrom(
                            padding: const EdgeInsets.symmetric(
                                horizontal: 6, vertical: 4)),
                      ),
                      TextButton.icon(
                        onPressed: _scanning ? null : _discoverPrinters,
                        icon: const Icon(Icons.radar,
                            size: 14, color: _crimson),
                        label: const Text('Scan',
                            style: TextStyle(color: _crimson, fontSize: 12)),
                        style: TextButton.styleFrom(
                            padding: const EdgeInsets.symmetric(
                                horizontal: 6, vertical: 4)),
                      ),
                    ],
                  ),
                ),
                if (_scanning)
                  const LinearProgressIndicator(
                    minHeight: 3,
                    backgroundColor: _crimsonLight,
                    color: _crimson,
                  ),

                // ── Manual MAC entry ──────────────────────────────────────────
                Padding(
                  padding: const EdgeInsets.fromLTRB(12, 12, 12, 4),
                  child: Row(
                    children: [
                      Expanded(
                        child: TextField(
                          controller: _macController,
                          style: const TextStyle(
                              color: Colors.black87, fontSize: 14),
                          textCapitalization: TextCapitalization.characters,
                          onSubmitted: (_) => _addManualMac(),
                          decoration: InputDecoration(
                            hintText: 'Enter MAC (e.g. C4:D3:6A:AC:F0:AE)',
                            hintStyle: const TextStyle(
                                color: Colors.grey, fontSize: 13),
                            filled: true,
                            fillColor: Colors.white,
                            prefixIcon: const Icon(Icons.bluetooth_searching,
                                color: _crimson, size: 18),
                            contentPadding: const EdgeInsets.symmetric(
                                horizontal: 12, vertical: 10),
                            border: OutlineInputBorder(
                                borderRadius: BorderRadius.circular(8),
                                borderSide: const BorderSide(
                                    color: Color(0xFFE0E0E0))),
                            enabledBorder: OutlineInputBorder(
                                borderRadius: BorderRadius.circular(8),
                                borderSide: const BorderSide(
                                    color: Color(0xFFE0E0E0))),
                            focusedBorder: OutlineInputBorder(
                                borderRadius: BorderRadius.circular(8),
                                borderSide: const BorderSide(
                                    color: _crimson, width: 1.5)),
                          ),
                        ),
                      ),
                      const SizedBox(width: 8),
                      ElevatedButton(
                        onPressed: _addManualMac,
                        style: ElevatedButton.styleFrom(
                          backgroundColor: _crimson,
                          foregroundColor: Colors.white,
                          padding: const EdgeInsets.symmetric(
                              horizontal: 14, vertical: 13),
                          shape: RoundedRectangleBorder(
                              borderRadius: BorderRadius.circular(8)),
                        ),
                        child: const Text('Add',
                            style: TextStyle(fontWeight: FontWeight.bold)),
                      ),
                    ],
                  ),
                ),

                // ── Printer list ──────────────────────────────────────────────
                Expanded(
                  child: _printers.isEmpty
                      ? Center(
                          child: Padding(
                            padding: const EdgeInsets.all(24),
                            child: Column(
                              mainAxisSize: MainAxisSize.min,
                              children: [
                                Icon(
                                  _scanning
                                      ? Icons.radar
                                      : Icons.bluetooth_disabled,
                                  size: 56,
                                  color: _crimson.withOpacity(0.25),
                                ),
                                const SizedBox(height: 14),
                                Text(
                                  _scanning
                                      ? 'Searching for Bluetooth printers…'
                                      : 'No printers found.\nPair your Zebra printer in Android Bluetooth settings,\nthen tap "Paired" — or enter the MAC address manually.',
                                  textAlign: TextAlign.center,
                                  style: TextStyle(
                                      color: Colors.grey[600], fontSize: 13),
                                ),
                              ],
                            ),
                          ),
                        )
                      : ListView.builder(
                          padding:
                              const EdgeInsets.fromLTRB(12, 8, 12, 12),
                          itemCount: _printers.length,
                          itemBuilder: (_, i) {
                            final p = _printers[i];
                            return Container(
                              margin: const EdgeInsets.only(bottom: 8),
                              decoration: BoxDecoration(
                                color: Colors.white,
                                borderRadius: BorderRadius.circular(10),
                                border: Border.all(
                                    color: const Color(0xFFE8E8E8)),
                                boxShadow: [
                                  BoxShadow(
                                    color: Colors.black.withOpacity(0.04),
                                    blurRadius: 4,
                                    offset: const Offset(0, 2),
                                  ),
                                ],
                              ),
                              child: ListTile(
                                contentPadding:
                                    const EdgeInsets.symmetric(
                                        horizontal: 12, vertical: 4),
                                leading: Container(
                                  width: 40,
                                  height: 40,
                                  decoration: BoxDecoration(
                                    color: _crimsonLight,
                                    shape: BoxShape.circle,
                                  ),
                                  child: const Icon(Icons.bluetooth,
                                      color: _crimson, size: 20),
                                ),
                                title: Text(p.name,
                                    style: const TextStyle(
                                        color: Colors.black87,
                                        fontWeight: FontWeight.w600,
                                        fontSize: 14)),
                                subtitle: Text(p.address,
                                    style: TextStyle(
                                        color: Colors.grey[500],
                                        fontSize: 12)),
                                trailing: ElevatedButton.icon(
                                  onPressed: () => _printTo(p),
                                  icon: const Icon(Icons.print, size: 15),
                                  label: const Text('Print',
                                      style: TextStyle(fontSize: 13)),
                                  style: ElevatedButton.styleFrom(
                                    backgroundColor: _crimson,
                                    foregroundColor: Colors.white,
                                    padding: const EdgeInsets.symmetric(
                                        horizontal: 12, vertical: 8),
                                    shape: RoundedRectangleBorder(
                                        borderRadius:
                                            BorderRadius.circular(8)),
                                  ),
                                ),
                              ),
                            );
                          },
                        ),
                ),
              ],
            ),
    );
  }
}
